# Required: AI Builders (OpenAI-compatible gateway)
AI_BUILDER_TOKEN=

# Notes root: only Markdown under this folder is indexed (「关于亲密关系」专题)
# Path to your Obsidian folder (Markdown only under this directory is indexed)
VAULT_PATH=./notes

# Gateway (default: AI Builders)
AI_API_BASE_URL=https://space.ai-builders.com/backend/v1

# If chat shows connection errors, set your local proxy (VPN client often exposes this port):
# HTTPS_PROXY=http://127.0.0.1:7890

# Models (confirmed defaults)
AI_CHAT_MODEL=deepseek
AI_EMBEDDING_MODEL=text-embedding-3-small

# Tag routing: embed vault tags, fuse lexical + embedding scores, then limit search
# to notes whose YAML/frontmatter tags match (OR). See README for details.
TAG_ROUTING_ENABLED=true
TAG_ROUTING_TOP_N=3
TAG_ROUTING_POOL=56
TAG_ROUTING_MIN_CHUNKS=6
TAG_ROUTING_ABSOLUTE_MIN_CHUNKS=3

# Fused score = TAG_ROUTE_LEX_WEIGHT * lexical(query,tag) + TAG_ROUTE_EMB_WEIGHT * emb_sim
TAG_ROUTE_LEX_WEIGHT=0.7
TAG_ROUTE_EMB_WEIGHT=0.3
TAG_ROUTE_COMBINED_FLOOR=0.14

# If #1 fused tag beats #2 by at least this gap, only the top tag is used to scope (reduces pollution from runner-up tags).
TAG_ROUTE_SCOPE_PRIMARY_GAP=0.08

# Retrieval diversity: how many chunks to send to the model, and max chunks per note
# before other notes get slots (then backfill so the list stays full).
RETRIEVE_TOP_K=12
RETRIEVE_MAX_CHUNKS_PER_NOTE=4

# If embeddings API is unavailable, indexer falls back to BM25 automatically.

# --- Accounts (recommended for shared hosting) ---
# Create users in data/users.db, or bootstrap on first start (only if users.db is empty):
# USERS_BOOTSTRAP=alice:her-pass,bob:his-pass
# Keep users.db across redeploys (upload zip or raw db):
# USERS_DB_URL=https://your-storage/relationship-expert-data.zip

# Legacy single shared password (only used when users.db has no accounts)
APP_PASSWORD=
SESSION_SECRET=

# --- Hosted public deploy (ai-builders.space) ---
# PUBLIC_DEPLOY=true
# PROJECT_ROOT=/app
# DATA_DIR=/app/data
# INDEX_BUNDLE_URL=https://your-private-host/relationship-expert-index.zip
